# Entity MC — Agent Manifest Template
# Copy this file and fill in your values:
#   cp template.env my-agent.env
#   edit my-agent.env
#   bash ../install.sh --manifest my-agent.env

# REQUIRED: Your agent's display name in Mission Control
ENTITY_MC_AGENT_NAME="MyAgent"

# REQUIRED: Your OpenClaw workspace root (where scripts/ lives)
ENTITY_MC_TARGET_HOME="$HOME/clawd"

# OPTIONAL: Where MC scripts get installed (default: $TARGET_HOME/scripts)
# ENTITY_MC_TARGET_SCRIPTS_DIR="$HOME/clawd/scripts"

# OPTIONAL: State directory for releases, backups, logs (default: $TARGET_HOME/.entity-mc)
# ENTITY_MC_STATE_DIR="$HOME/clawd/.entity-mc"

# OPTIONAL: Install mode — "copy" (wrapper stubs) or "symlink" (direct links)
ENTITY_MC_MODE="copy"

# OPTIONAL: Install cron jobs for auto-pull and stall-check
ENTITY_MC_INSTALL_CRON="true"

# OPTIONAL: Enable auto-pull (agent picks up todo tasks automatically)
ENTITY_MC_ENABLE_AUTO_PULL="true"

# OPTIONAL: Enable stall-check (alerts on tasks stuck in doing >24h)
ENTITY_MC_ENABLE_STALL_CHECK="true"

# OPTIONAL: Cron schedules (default: auto-pull every 30 min, stall-check every 2h)
ENTITY_MC_AUTO_PULL_SCHEDULE="*/30 * * * *"
ENTITY_MC_STALL_CHECK_SCHEDULE="0 */2 * * *"

# OPTIONAL: OpenClaw profile name (if using named profiles)
# ENTITY_MC_PROFILE_NAME="my-profile"

# OPTIONAL: Runtime type — "openclaw" or "hermes"
ENTITY_MC_RUNTIME="openclaw"

# OPTIONAL: Path to openclaw binary (auto-detected if on PATH)
# ENTITY_MC_OPENCLAW_BIN="/usr/local/bin/openclaw"

# OPTIONAL: Notes for your reference
ENTITY_MC_EXTRA_NOTES=""
